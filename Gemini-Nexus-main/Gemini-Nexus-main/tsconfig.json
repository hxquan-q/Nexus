{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "types": ["node"],
        "moduleResolution": "bundler",
        "strict": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true
    },
    "exclude": ["dist", "artifacts", "vendor"]
}
